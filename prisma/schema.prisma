generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OppType {
  BID
  PQQ
  RFQ
  EOI
  NDA
  TENDER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Result {
  NONE
  AWARDED
  LOST
  CANCELLED
}

enum Role {
  ADMIN
  EDITOR
  CONTRIBUTOR
  VIEWER
}

model User {
  id        String  @id @default(cuid())
  name      String
  email     String  @unique
  roleTitle String
  access    Role    @default(CONTRIBUTOR)
  // Real auth + RBAC (Phase 6). `role` is a permission-role key (admin, bd_manager,
  // proposal_manager, tender_coordinator, document_controller, commercial_manager,
  // finance, management_viewer, reviewer). `group` is a notification team group.
  role         String   @default("bd_manager")
  group        String   @default("")
  passwordHash String   @default("")
  active       Boolean  @default(true)
  lastLogin    DateTime?
  avatarHue Int     @default(250)
  initials  String  @default("")
  ownedOpps    Opportunity[] @relation("owner")
  reviewedOpps Opportunity[] @relation("reviewer")
  sessions     Session[]
  createdAt DateTime @default(now())
}

// httpOnly cookie session (Phase 6 auth). Revocable by deleting the row.
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Client {
  id       String @id @default(cuid())
  name     String
  sector   String @default("")
  contact  String @default("")
  portal   String @default("")
  loginRef String @default("")
  wins     Int    @default(0)
  losses   Int    @default(0)
  opps     Opportunity[]
}

model StatusConfig {
  id    String @id @default(cuid())
  label String @unique
  stage String
  hue   Int
  order Int
  opps  Opportunity[]
}

model Opportunity {
  id             String   @id @default(cuid())
  ref            String   @unique
  rfpNumber      String?
  title          String
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  portal         String   @default("")
  type           String   @default("BID")
  classification String   @default("")
  procurement    String   @default("")
  statusId       String
  status         StatusConfig @relation(fields: [statusId], references: [id])
  priority       String   @default("MEDIUM")
  ownerId        String?
  owner          User?    @relation("owner", fields: [ownerId], references: [id])
  reviewerId     String?
  reviewer       User?    @relation("reviewer", fields: [reviewerId], references: [id])

  partnerInvolved  Boolean @default(false)
  partnerName      String  @default("")
  contractDuration String  @default("")

  rfpReceived      DateTime?
  siteVisit        DateTime?
  siteVisitMode    String   @default("date") // date | tbc | not_required
  questionDeadline DateTime?
  qDeadlineTime    String   @default("")     // HH:mm
  bidDue           DateTime?
  bidDueTime       String   @default("")     // HH:mm
  submission       DateTime?
  followUp         DateTime?

  bondRequired     Boolean  @default(false)
  bondPct          Float    @default(0)
  bondValidity     DateTime?
  bondValidityDays Int?

  result        String   @default("NONE")
  estValue      Float    @default(0)
  notes         String   @default("")

  // Closed/Lost reason (Fix 3) — real stored reason, never random.
  closedReasonCategory String?
  closedReasonNotes    String   @default("")
  closedById           String?
  closedAt             DateTime?
  archivedAt           DateTime?
  // Second follow-up date (template "FOLLOW-UP DATE (THREE)" column).
  followUpTwo          DateTime?

  checklist     String?  // JSON string
  documents     Document[]
  followUps     FollowUp[]
  activity      ActivityLog[]
  reminders     Reminder[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Document {
  id        String  @id @default(cuid())
  oppId     String
  name      String
  url       String  @default("")
  label     String  @default("Other")
  kind      String  @default("file")
  meta      String  @default("")
  createdAt DateTime @default(now())
  opp       Opportunity @relation(fields: [oppId], references: [id], onDelete: Cascade)
}

model FollowUp {
  id    String   @id @default(cuid())
  oppId String
  n     Int
  label String
  dueAt DateTime?
  done  Boolean  @default(false)
  opp   Opportunity @relation(fields: [oppId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  oppId     String
  userId    String?
  verb      String
  createdAt DateTime @default(now())
  opp       Opportunity @relation(fields: [oppId], references: [id], onDelete: Cascade)
}

// Saved table/board views (Fix 1) — persisted per user, scoped to a page route.
model SavedView {
  id       String  @id @default(cuid())
  userId   String
  route    String  @default("/opportunities") // which page the view belongs to
  name     String
  config   String  // JSON: filters / sort / grouping / hidden columns
  isShared Boolean @default(false)
  order    Int     @default(0)
  createdAt DateTime @default(now())
}

// Change History / audit trail (Feature 2). One row per recorded action.
model ChangeEvent {
  id               String   @id @default(cuid())
  userId           String   @default("")
  userName         String   @default("")
  userInitials     String   @default("")
  actionType       String   // status_changed | field_edited | created | deleted | excel_export | …
  oppId            String?
  oppRef           String   @default("")
  oppTitle         String   @default("")
  fieldChanged     String   @default("")
  oldValue         String   @default("")
  newValue         String   @default("")
  source           String   @default("dashboard") // dashboard | excel_import | excel_export | system
  importance       String   @default("normal")    // normal | major
  excelStatus      String   @default("")           // ready | exported | pending | failed | ''
  emailStatus      String   @default("")           // '' | sent | sent_demo | failed | skipped
  recipients       String   @default("")           // JSON array of recipient ids
  recipientsSummary String  @default("")
  userNote         String   @default("")
  readableSummary  String   @default("")
  createdAt        DateTime @default(now())

  @@index([oppId])
  @@index([createdAt])
}

// Notification rules (Feature 3) — which field changes are "major" + email policy.
model NotificationRule {
  id              String  @id @default(cuid())
  field           String  @unique // field key or transition key
  label           String  @default("")
  isMajor         Boolean @default(true)
  allowSkipEmail  Boolean @default(false)
  createdAt       DateTime @default(now())
}

// Notification events (Feature 3) — log of emails sent/simulated.
model NotificationEvent {
  id               String   @id @default(cuid())
  changeId         String?
  oppId            String?
  subject          String   @default("")
  recipients       String   @default("") // JSON
  recipientsSummary String  @default("")
  status           String   @default("sent_demo") // sent | sent_demo | failed
  note             String   @default("")
  createdAt        DateTime @default(now())
}

// Excel import runs (Feature 1).
model ExcelImport {
  id          String   @id @default(cuid())
  fileName    String   @default("")
  rowsAdded   Int      @default(0)
  rowsUpdated Int      @default(0)
  warnings    Int      @default(0)
  failed      Int      @default(0)
  status      String   @default("completed") // completed | needs_review | failed
  errors      String   @default("")          // JSON array of {sheet,row,message}
  byUserId    String   @default("")
  createdAt   DateTime @default(now())
}

// Excel export runs (Feature 1).
model ExcelExport {
  id        String   @id @default(cuid())
  fileName  String   @default("")
  rows      Int      @default(0)
  status    String   @default("exported") // exported | failed
  byUserId  String   @default("")
  createdAt DateTime @default(now())
}

// Generic editable dropdown lists (portals, classifications, procurement
// methods, partners, site-visit options, bond-validity presets, opp types).
model ListOption {
  id        String   @id @default(cuid())
  category  String // portal | classification | procurement | partner | site_visit | bond_validity | opp_type
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([category, label])
}

// Real calendar reminders, optionally linked to an opportunity.
model Reminder {
  id        String       @id @default(cuid())
  oppId     String?
  opp       Opportunity? @relation(fields: [oppId], references: [id], onDelete: Cascade)
  type      String // bid_due | question_deadline | site_visit | internal_review | commercial_review | bond_expiry | follow_up | custom
  title     String
  date      DateTime
  time      String       @default("") // HH:mm
  notes     String       @default("")
  done      Boolean      @default(false)
  createdAt DateTime     @default(now())
}
